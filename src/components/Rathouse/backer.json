{
  "$schema": "rathouse-backer-data",
  "generatedAt": "April 26, 2026",
  "notes": {
    "valueOf": "valueOf(stake): if phase==='holding' use mkt; if phase==='settled' use paid; else cost.",
    "formulas": {
      "portfolioValue": "sum(valueOf(stake) for all stakes)",
      "costBasis": "sum(stake.cost)",
      "unrealized": "sum(stake.mkt - stake.cost) for stakes where phase===\"holding\"",
      "realized": "sum(stake.paid - stake.cost) for stakes where phase===\"settled\"",
      "pl": "unrealized + realized",
      "sharePctAtClose": "(stake.cost / project.goal) * (project.poolPct)  // pool default = 30% of first sale"
    },
    "formattersUsed": {
      "fmtSigned": "(n) => (n>=0 ? \"+\" : \"−\") + \"€\" + Math.abs(Math.round(n))",
      "fmtPct": "(n) => (n>=0 ? \"+\" : \"−\") + Math.abs(n).toFixed(1) + \"%\""
    }
  },
